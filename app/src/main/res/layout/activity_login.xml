<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".account.Login" >

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="XIN CHÀO"
        android:gravity="center"
        android:padding="30dp"
        android:textStyle="bold"
        android:layout_marginBottom="25dp"
        android:textSize="26dp"
        android:textColor="@color/theme_tele"/>

    <com.google.android.material.textfield.TextInputLayout
        xmlns:app="http://schemas.android.com/apk/res-auto"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:id="@+id/etUsernameLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="0dp"
        android:layout_margin="10dp"
        app:startIconDrawable="@drawable/ic_person_24"
        app:startIconTint="@color/theme_tele"
        app:endIconMode="clear_text"
        android:hint="Tên đăng nhập"
        android:textColorHint="@color/theme_tele"
        >

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="15dp"
            android:padding="15dp"
            android:text="thuthu001"
            android:textColor="@color/theme_tele"
            android:textStyle="bold"
            android:background="#D3D3D3"
            />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        xmlns:app="http://schemas.android.com/apk/res-auto"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:id="@+id/etPasswordLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:passwordToggleEnabled="true"
        app:passwordToggleTint="@color/theme_tele"
        android:layout_margin="10dp"
        android:layout_marginBottom="5dp"
        app:startIconDrawable="@drawable/ic_password_24"
        app:startIconTint="@color/theme_tele"
        android:hint="Mật khẩu"
        android:textColorHint="@color/theme_tele"

        >

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textColor="@color/theme_tele"
            android:text="abc001"
            android:textStyle="bold"
            android:background="#D3D3D3"/>
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="5dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="5dp"
        android:layout_marginBottom="5dp"
        android:backgroundTint="@color/theme_tele"
        android:padding="10dp"
        android:text="Đăng nhập"
        android:textColor="#D0EAE7" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chưa có tài khoản? "
            android:textColor="@color/black"
            android:textSize="14sp"
            android:gravity="center"
            android:clickable="true"/>
        <TextView
            android:id="@+id/tvRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đăng ký"
            android:textColor="@color/theme_tele"
            android:textStyle="bold"
            android:textSize="16sp"
            android:gravity="center"
            android:clickable="true"/>
    </LinearLayout>

    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvFooter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:gravity="center"
            android:paddingBottom="10dp"
            android:text="Võ Văn Dương"
            android:textStyle="italic"
            android:textColor="#000000"
            android:textSize="14dp" />
    </RelativeLayout>

</LinearLayout>